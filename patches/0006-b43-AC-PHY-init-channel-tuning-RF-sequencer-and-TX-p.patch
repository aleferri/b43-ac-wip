+		b43_phy_read_log(dev, 0x0678 + stride);
+		b43_phy_maskset(dev, 0x0678 + stride, (u16)~0x0001, 0);
+	}
+
+	/* Trailer (1 op): gate unlock */
+	b43_phy_maskset(dev, B43_PHY_AC_REG_TBL_WRITE_GATE, (u16)~0x0002, 0);
