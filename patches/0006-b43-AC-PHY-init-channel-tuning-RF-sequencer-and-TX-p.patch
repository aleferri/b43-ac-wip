+	b43_mac_enable(dev);
+	b43_maccontrol_set(dev, ~0x48020000u, 0x40000000);  /* multi-bit config */
+	b43_mac_suspend(dev);
+	b43_maccontrol_set(dev, ~0x00040000u, 0);           /* clr bit 18 */
+	b43_mac_enable(dev);
+	b43_phy_ac_mhf_maskset(dev, 0, (u16)~0x4000, 0);
+	b43_mac_suspend(dev);
